# Secrets are sourced from the 1Password "Events" vault.
# Populate .env.local with:  pnpm setup:secrets   (runs `op inject`)
#
# NOTE: Convex DEPLOYMENT env vars (JWT_PRIVATE_KEY, JWKS, OPENROUTER_API_KEY,
# RESEND_API_KEY, SITE_URL, AUTH_EMAIL_FROM) are set ON each Convex deployment
# via `npx convex env set`, NOT from this file. This file only configures the
# local shell / Expo build.

# Convex (local dev deployment)
CONVEX_DEPLOYMENT=
EXPO_PUBLIC_CONVEX_URL=http://127.0.0.1:3210

# Expo / EAS (CI + builds). Items hold per-env fields (dev/staging/production).
EXPO_TOKEN=op://Events/EXPO_TOKEN/dev

# Shared API keys (also set on the Convex deployment via `convex env set`)
OPENROUTER_API_KEY=op://Events/OPENROUTER_SECRET_KEY/dev
RESEND_API_KEY=op://Events/RESEND_API_KEY/dev

# Finance vendors (Convex deployment env vars; finance degrades to no-op when
# unset). Stripe = ticketing + Financial Connections read-sync; Increase =
# the money layer (ACH payouts + card issuing). Set per env on the deployment.
STRIPE_SECRET_KEY=op://Events/STRIPE_SECRET_KEY/dev
STRIPE_WEBHOOK_SECRET=op://Events/STRIPE_WEBHOOK_SECRET/dev
# Stripe publishable key (public — safe to expose). Set on the Convex deployment;
# createFcSession returns it to the browser so Stripe.js can init the Financial
# Connections linking. 1Password item is named EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY.
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=op://Events/EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY/dev
INCREASE_API_KEY=op://Events/INCREASE_API_KEY/dev
# The webhook "Shared Secret" (SAME value in the sandbox + prod Increase
# dashboards). Verifies both, since the signature is over id.timestamp.body.
INCREASE_WEBHOOK_SECRET=op://Events/INCREASE_WEBHOOK_SECRET/dev
# Sandbox Increase key. The ONE /increase/webhook endpoint (on the prod Convex
# deployment) serves BOTH prod and sandbox webhooks — a `sandbox_`-prefixed
# object id routes the follow-up API calls to sandbox.increase.com with THIS
# key. Set it on the prod deployment (= the dev-field Increase key) so sandbox
# webhooks can be serviced; unset elsewhere.
INCREASE_SANDBOX_API_KEY=op://Events/INCREASE_API_KEY/dev
# OPTIONAL override for the Increase Program a chapter's Account is opened under.
# A nonprofit has exactly ONE Increase Program, so provisioning auto-resolves it
# via GET /programs — leave this unset unless the org ever has multiple programs.
# (prod: program_3lxxmr4tc9wazoonyi7y · sandbox: sandbox_program_uzcjf5ppbi33tgk3le35)
# INCREASE_PROGRAM_ID=op://Events/INCREASE_PROGRAM_ID/dev
# The ONE shared org Entity (the legal nonprofit "Global Echo Charitable Co",
# KYB-verified once in the Increase dashboard). Every chapter is an ACCOUNT under
# this single entity — the app never creates entities. Per-env (sandbox vs prod).
# Sandbox entity id: sandbox_entity_fyqn5ygrs6jrtitofxm9.
INCREASE_ENTITY_ID=op://Events/INCREASE_ENTITY_ID/dev
# The SANDBOX org Entity, on the prod deployment too, so the runtime sandbox-mode
# toggle (financeSettings.sandboxMode) can provision test chapter accounts under
# it. It IS the sandbox entity (= INCREASE_ENTITY_ID's dev field), synced the same
# way as INCREASE_SANDBOX_API_KEY. (sandbox_entity_fyqn5ygrs6jrtitofxm9)
INCREASE_SANDBOX_ENTITY_ID=op://Events/INCREASE_ENTITY_ID/dev
# Increase API base URL. Dev/staging use the SANDBOX; production leaves this
# unset (code defaults to https://api.increase.com). Set on the dev/staging
# Convex deployments via `convex env set INCREASE_API_BASE https://sandbox.increase.com`.
INCREASE_API_BASE=https://sandbox.increase.com
